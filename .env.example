# ======================================================
# 825 SHOP - Discord Bot Configuration
# Salin file ini menjadi .env dan isi nilainya
# ======================================================

# Token bot Discord kamu (dari Discord Developer Portal)
DISCORD_TOKEN=YOUR_BOT_TOKEN_HERE

# ID Guild/Server Discord kamu
GUILD_ID=YOUR_GUILD_ID_HERE

# ID Channel untuk panel ticket (tempat tombol "Buat Ticket" dikirim)
TICKET_PANEL_CHANNEL_ID=YOUR_PANEL_CHANNEL_ID_HERE

# ID Channel kategori untuk ticket (ticket akan dibuat di sini)
TICKET_CATEGORY_ID=YOUR_TICKET_CATEGORY_ID_HERE

# ID Channel untuk testimoni (ticket yang selesai pindah ke sini)
TESTIMONI_CHANNEL_ID=YOUR_TESTIMONI_CHANNEL_ID_HERE

# ID Role staff/admin yang bisa melihat dan menutup ticket
STAFF_ROLE_ID=YOUR_STAFF_ROLE_ID_HERE

# URL domain deployment kamu (untuk self-ping UptimeRobot)
# Format: https://nama-repl.replit.app  (tanpa trailing slash)
# Daftarkan URL ini ke UptimeRobot: https://nama-repl.replit.app/api/healthz
API_URL=

# URL Banner 825 SHOP (opsional, bisa pakai attachment)
# Kosongkan jika ingin pakai banner dari file lokal
BANNER_URL=
